                    {
                      "type": "text",
                      "id": "XA3U9",
                      "name": "adminText",
                      "fill": "#555555",
                      "content": "Purpose: central admin workspace for tenant operations.\nKey UI blocks: overview stats, tenant table + edit panel, room occupancy board, assignment form, bill generation, payment review, visitor log, reporting cards.\nPrimary action: manage tenant lifecycle and operational records.",
